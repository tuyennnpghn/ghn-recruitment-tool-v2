# Environment Variables — Backend
# Copy this file to .env and fill in the actual values

# === Database ===
# Pooled connection (used by app at runtime) — port 6543 if using Supabase pooler, or 5432 for direct
DATABASE_URL="postgresql://postgres.xxxx:your_password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require"
# Direct connection (used by Prisma migrate/seed) — always port 5432
DIRECT_URL="postgresql://postgres.xxxx:your_password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# === JWT ===
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="8h"

# === Supabase Storage ===
SUPABASE_URL="https://your-ref.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"
SUPABASE_CV_BUCKET="candidate-cvs"

# === App ===
PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# === Throttle ===
THROTTLE_TTL=60
THROTTLE_LIMIT=100
apps/backend/.env.example
SUPABASE_CV_BUCKET=candidate-cvs